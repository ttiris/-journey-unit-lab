# Docker-compatible environment variables for local development

# Database
MONGODB_URI=mongodb://mongo:27017/journey-unit-lab

# Authentication
JWT_SECRET=super-secret-jwt-key
JWT_EXPIRE=7d

# AI Service
AI_SERVICE=OPENAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# File Storage
STORAGE_SERVICE=AWS_S3
AWS_S3_BUCKET=journey-unit-lab-assets
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000
