# ============================================
# Journey Unit Lab - Environment Variables
# ============================================

# ============ DATABASE ============
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/journey-unit-lab

# ============ AUTHENTICATION ============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# ============ AI SERVICES ============
# Use one of: OPENAI or CLAUDE
AI_SERVICE=OPENAI

# OpenAI Configuration
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# Claude Configuration (alternative)
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-opus-20240229

# ============ FILE STORAGE ============
# Use one of: AWS_S3 or ALIYUN_OSS
STORAGE_SERVICE=AWS_S3

# AWS S3 Configuration
AWS_S3_BUCKET=journey-unit-lab-assets
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Aliyun OSS Configuration (alternative)
ALIYUN_REGION=oss-cn-beijing
ALIYUN_BUCKET=journey-unit-lab
ALIYUN_ACCESS_KEY_ID=...
ALIYUN_ACCESS_KEY_SECRET=...

# ============ SERVER CONFIGURATION ============
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ============ FRONTEND CONFIGURATION ============
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000
